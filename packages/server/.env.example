# Nimbus Server — Environment Variables
# On Railway, set these as service variables instead of using a .env file.

# Anthropic API key (server-side fallback when a request omits its own key).
# Optional if you only use BYOK (bring-your-own-key) from the client.
ANTHROPIC_API_KEY=

# Comma-separated list of allowed CORS origins.
# For a single-service deploy this is optional — the Railway public domain is
# auto-allowed via RAILWAY_PUBLIC_DOMAIN. Set for custom domains / split deploys.
# Example: https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# Stripe Payment Links for the optional tip jar (leave blank to disable).
STRIPE_TIP_LINK_SMALL=
STRIPE_TIP_LINK_MEDIUM=
STRIPE_TIP_LINK_LARGE=

# Override the path to the built frontend (defaults to ../app/dist). Rarely needed.
# CLIENT_DIST=

# Set to 1 to trust the proxy when not running with NODE_ENV=production.
# TRUST_PROXY=1
