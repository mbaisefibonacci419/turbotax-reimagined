node_modules/
dist/
.env
*.local

*.tsbuildinfo

# Emitted TypeScript declaration artifacts in package source trees. The client
# build is noEmit and the shared library emits real declarations to dist/, so
# any *.d.ts under src/ is stray `tsc` output that is never imported. Keep
# hand-written ambient declarations.
packages/client/src/**/*.d.ts
packages/shared/src/**/*.d.ts
!packages/client/src/vite-env.d.ts
!packages/client/src/speech.d.ts

# OS files
.DS_Store

# SQLite database files (match anywhere, including packages/server/data/)
*.db
*.db-shm
*.db-wal

# Claude project files
.claude/

# Test artifacts
client/playwright-report/
client/test-results/

# AI eval scorecards (contain model-specific results, regenerated on demand)
evals/*.json

# Internal audit & review docs
client/SECURITY-AUDIT*.md
client/UX-REVIEW*.md
*.rtf

# Python venv for Docling PDF extraction
.docling-venv/

# Archive (private files, research, strategy, test data)
Archive/
