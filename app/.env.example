# Nimbus Frontend (app) — Vite build-time variables.
# These are inlined into the bundle at build time (must be present when `vite build` runs).

# Base URL for the backend API.
# Leave EMPTY for a single-service deploy (Express serves the frontend on the same origin).
# Set to a full URL (e.g. https://api.example.com) only for a separate backend service.
VITE_API_BASE=

# Syncfusion Essential JS 2 — Community License Key.
# Free for individuals and companies with <$1M revenue and <5 developers.
# Get yours at: https://www.syncfusion.com/account/claim-license-key
VITE_SYNCFUSION_LICENSE_KEY=
